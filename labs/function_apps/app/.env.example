FUNCTIONS_WORKER_RUNTIME=python
AzureWebJobsStorage=DefaultEndpointsProtocol=https;AccountName=<storage-account>;AccountKey=<storage-key>;EndpointSuffix=core.windows.net

COSMOS_ENDPOINT=https://<cosmos-account>.documents.azure.com:443/
COSMOS_KEY=<cosmos-key>
COSMOS_DATABASE_NAME=portfolio-db
COSMOS_CONTAINER_NAME=users

EMAIL_FROM=sender@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=<smtp-username>
SMTP_PASSWORD=<smtp-password>

TIMER_SCHEDULE=0 */5 20-21 * * 1-5
REPORT_MINUTE_ET=5

MARKET_DATA_PROVIDER_ORDER=twelvedata,finnhub,fmp,alphavantage
MARKET_DATA_TIMEOUT_SECONDS=20

TWELVEDATA_API_KEY=
TWELVEDATA_QUOTE_URL=https://api.twelvedata.com/quote

FINNHUB_API_KEY=
FINNHUB_QUOTE_URL=https://finnhub.io/api/v1/quote

FMP_API_KEY=
FMP_QUOTE_URL=https://financialmodelingprep.com/stable/quote

ALPHAVANTAGE_API_KEY=
ALPHAVANTAGE_QUOTE_URL=https://www.alphavantage.co/query
